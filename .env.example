# 事事如嗦 — Coze API 配置（复制为 .env 后填写）

# API 根地址（只填域名，不要加 /v3/chat）
# 国内: https://api.coze.cn  国际: https://api.coze.com
COZE_API_BASE=https://api.coze.com

# 个人访问令牌：Coze 后台 → API 授权 → 创建，以 pat_ 开头
COZE_API_TOKEN=pat_你的令牌

# 智能体 ID：打开智能体页面，URL 中 bot/ 后面的数字
COZE_BOT_ID=你的Bot_ID

# 用户标识（可保持默认）
COZE_USER_ID=user_local_001

# 本地服务端口
PORT=3000

# 未配置 Coze 时是否使用演示回复
DEMO_MODE=true
